# Combined env for the Docker container (api + indexer).
# Each service's own .env.example is the per-service reference for local dev.
#
# Postgres — point to your local instance from within Docker:
#   Mac/Windows (Docker Desktop): host.docker.internal
#   Linux: 172.17.0.1  (default bridge) or add `network_mode: host` to compose
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/fairdrop

# ── Shared ────────────────────────────────────────────────────────────────────

ALEO_RPC_URL=https://api.explorer.provable.com/v2/testnet
ALEO_NETWORK=testnet

# ── API ───────────────────────────────────────────────────────────────────────

PORT=3001
CORS_ORIGIN=http://localhost:5173
PINATA_JWT=

# ── Indexer ───────────────────────────────────────────────────────────────────

INDEXER_CONFIRMATION_DEPTH=10
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_BATCH_SIZE=50
INDEXER_START_BLOCK=1
