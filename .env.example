# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/fairdrop

# ── Aleo network ──────────────────────────────────────────────────────────────
# Values: testnet | mainnet
ALEO_NETWORK=testnet
ALEO_RPC_URL=https://api.explorer.aleo.org/v1/testnet

# ── Indexer ───────────────────────────────────────────────────────────────────
# How many confirmed blocks to lag behind chain tip (finality buffer)
INDEXER_CONFIRMATION_DEPTH=10
# Poll interval in milliseconds
INDEXER_POLL_INTERVAL_MS=5000
# Blocks fetched per iteration. The explorer API allows 5 req/s and 100k req/day.
# Each block = 1 RPC call; each create_auction adds ~2 more mapping reads.
# Keep at 20 during initial historical sync; raise to 50 when near chain tip.
INDEXER_BATCH_SIZE=20

# ── Credential Signer ─────────────────────────────────────────────────────────
# Ed25519 private key for signing off-chain gate credentials
SIGNER_PRIVATE_KEY=

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000
# Comma-separated allowed origins for CORS
API_CORS_ORIGINS=http://localhost:5173
