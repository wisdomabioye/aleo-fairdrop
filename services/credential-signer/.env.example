# ─── Required ────────────────────────────────────────────────────────────────

# Your Aleo private key. Used to sign credentials on-chain.
# Generate one: snarkos account new
# NEVER commit or share this value.
ISSUER_PRIVATE_KEY=APrivateKey1zkpXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Aleo RPC node used to read the current block height for credential expiry.
ALEO_RPC_URL=https://api.explorer.provable.com/v1

# Which access-control strategy to run.  One of: allowlist | webhook | token-gate | custom
CHECK_STRATEGY=allowlist

# ─── Optional ────────────────────────────────────────────────────────────────

# HTTP port. Default: 3002
# PORT=3002

# Credential validity in Aleo blocks. Default 5760 ≈ 24 h at 15 s/block.
# CREDENTIAL_TTL_BLOCKS=5760

# Allowed CORS origin. Set to your frontend URL in production.
# CORS_ORIGIN=https://fairdrop.xyz

# ─── Strategy: allowlist ─────────────────────────────────────────────────────
# Path to a local JSON file or a remote URL containing an array of Aleo addresses.

ALLOWLIST_SOURCE=file://./allowlist.json
# ALLOWLIST_SOURCE=https://example.com/allowlist.json

# ─── Strategy: webhook ───────────────────────────────────────────────────────
# URL of your own HTTP endpoint that decides whether an address is allowed.

# WEBHOOK_URL=https://yourapp.com/gate/check

# ─── Strategy: token-gate ────────────────────────────────────────────────────
# On-chain token ID (field literal) and minimum balance required.

# TOKEN_GATE_TOKEN_ID=123field
# TOKEN_GATE_MIN_BALANCE=1

# ─── Strategy: custom ────────────────────────────────────────────────────────
# Path to your custom check module, relative to this directory.
# The file must export a default async function: (address, auctionId) => boolean

# CHECK_MODULE=./my-check.ts
