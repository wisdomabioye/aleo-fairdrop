# ── Database ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/fairdrop

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3001

# Allowed CORS origin — set to the frontend URL.
CORS_ORIGIN=http://localhost:5173

# ── Aleo node ─────────────────────────────────────────────────────────────────

# Used for GET /tokens/:id/metadata and GET /indexer/status chain tip reads.
# api.explorer.aleo.org enforces 5 req/s and 100k req/day.
ALEO_RPC_URL=https://api.explorer.provable.com/v2/testnet

# ── IPFS ──────────────────────────────────────────────────────────────────────

# Pinata JWT — required for POST /metadata.
# Get one at https://app.pinata.cloud → API Keys.
PINATA_JWT="eyJhbGciOiJ..."
