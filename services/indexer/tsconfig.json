{
  "compilerOptions": {
    "target":              "ES2022",
    "module":              "ESNext",
    "moduleResolution":    "Bundler",
    "types": ["node"],
    "strict":              true,
    "skipLibCheck":        true,
    "verbatimModuleSyntax": true,
    "noEmit":              true
  },
  "include": ["src/**/*.ts"]
}
