# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/fairdrop

# ── Aleo node ─────────────────────────────────────────────────────────────────

# Network identifier — "mainnet" or "testnet".
ALEO_NETWORK=testnet

# Aleo REST API base URL. api.explorer.aleo.org enforces 5 req/s and 100k req/day.
ALEO_RPC_URL=https://api.explorer.aleo.org/v1/testnet

# ── Indexer tuning (optional — defaults shown) ────────────────────────────────

# Blocks behind chain tip to wait before indexing (finality buffer).
# Default: 10
INDEXER_CONFIRMATION_DEPTH=10

# How often to poll the node for new blocks, in milliseconds.
# Default: 5000
INDEXER_POLL_INTERVAL_MS=5000

# Max blocks fetched per poll iteration. Each block = 1 RPC call;
# each create_auction = 2 extra mapping reads. Keep low during initial sync.
# Default: 20
INDEXER_BATCH_SIZE=20
