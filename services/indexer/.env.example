# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/fairdrop

# ── Aleo node ─────────────────────────────────────────────────────────────────

# Network identifier — "mainnet" or "testnet".
ALEO_NETWORK=testnet

# Aleo REST API base URL. api.explorer.provable.com enforces 5 req/s and 100k req/day.
ALEO_RPC_URL=https://api.explorer.provable.com/v2/testnet

# ── Indexer tuning (optional — defaults shown) ────────────────────────────────

# Blocks behind chain tip to wait before indexing (finality buffer).
# Default: 10
INDEXER_CONFIRMATION_DEPTH=10

# How often to poll the node for new blocks, in milliseconds.
# Default: 5000
INDEXER_POLL_INTERVAL_MS=5000

# Max blocks fetched per poll iteration via getBlockRange (API cap: 50).
# One batch = 1 RPC call; each create_auction = 2 extra mapping reads.
# Default: 50 (saturates the API batch limit)
INDEXER_BATCH_SIZE=50

# Block height to start from on cold start (no DB checkpoint).
# Set this to the fairdrop contract deployment block to skip irrelevant history.
# Default: 1 (scans from genesis — correct but slow for a fresh deployment)
INDEXER_START_BLOCK=1
