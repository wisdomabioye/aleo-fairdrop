{
  "compilerOptions": {
    "target":                        "ES2022",
    "lib":                           ["ES2022", "DOM", "DOM.Iterable"],
    "module":                        "ESNext",
    "moduleResolution":              "Bundler",
    "jsx":                           "react-jsx",
    "strict":                        true,
    "skipLibCheck":                  true,
    "noEmit":                        true,
    "esModuleInterop":               true,
    "allowSyntheticDefaultImports":  true,
    "types":                         ["vite/client"],
    "baseUrl":                       ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
