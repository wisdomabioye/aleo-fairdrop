{
  "name": "@fairdrop/sdk",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "files": ["dist"],
  "exports": {
    "./parse":        "./src/parse/index.ts",
    "./credits":      "./src/credits/index.ts",
    "./format":       "./src/format/index.ts",
    "./cache":        "./src/cache/index.ts",
    "./client":       "./src/client.ts",
    "./token-registry": "./src/token-registry/index.ts",
    "./constants":    "./src/constants.ts",
    "./hash":         "./src/hash/index.ts",
    "./chain":        "./src/chain/index.ts",
    "./transactions": "./src/transactions/index.ts",
    "./multisig":     "./src/multisig/index.ts",
    "./records":      "./src/records/index.ts",
    "./price":        "./src/price/index.ts",
    "./dex":          "./src/dex/index.ts"
  },
  "publishConfig": {
    "exports": {
      "./parse": {
        "import": "./dist/parse.mjs",
        "types":  "./dist/parse.d.mts"
      },
      "./credits": {
        "import": "./dist/credits.mjs",
        "types":  "./dist/credits.d.mts"
      },
      "./format": {
        "import": "./dist/format.mjs",
        "types":  "./dist/format.d.mts"
      },
      "./cache": {
        "import": "./dist/cache.mjs",
        "types":  "./dist/cache.d.mts"
      },
      "./client": {
        "import": "./dist/client.mjs",
        "types":  "./dist/client.d.mts"
      },
      "./token-registry": {
        "import": "./dist/token-registry.mjs",
        "types":  "./dist/token-registry.d.mts"
      },
      "./constants": {
        "import": "./dist/constants.mjs",
        "types":  "./dist/constants.d.mts"
      },
      "./hash": {
        "import": "./dist/hash.mjs",
        "types":  "./dist/hash.d.mts"
      },
      "./chain": {
        "import": "./dist/chain.mjs",
        "types":  "./dist/chain.d.mts"
      },
      "./transactions": {
        "import": "./dist/transactions.mjs",
        "types":  "./dist/transactions.d.mts"
      },
      "./multisig": {
        "import": "./dist/multisig.mjs",
        "types":  "./dist/multisig.d.mts"
      },
      "./records": {
        "import": "./dist/records.mjs",
        "types":  "./dist/records.d.mts"
      },
      "./dex": {
        "import": "./dist/dex.mjs",
        "types":  "./dist/dex.d.mts"
      }
    }
  },
  "scripts": {
    "codegen":    "node scripts/codegen.mjs",
    "build":      "tsdown",
    "type-check": "tsc --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fairdrop/config": "workspace:*",
    "@fairdrop/types":  "workspace:*",
    "@fairdrop/leo-abigen":  "workspace:*"
  },
  "peerDependencies": {
    "@provablehq/sdk": "*"
  },
  "peerDependenciesMeta": {
    "@provablehq/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsdown":     "^0.21.7",
    "typescript": "~5.9.3",
    "vitest":     "^4.1.2"
  }
}
